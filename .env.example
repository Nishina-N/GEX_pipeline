# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# note.com セッションCookie（DevTools → Network → Cookie ヘッダーの _note_session_v5=xxx の値）
NOTE_SESSION_COOKIE=your_note_session_v5_value_here

# Cloudflare R2 (same credentials as stock-data-pipeline)
R2_ACCESS_KEY_ID=your_r2_access_key_here
R2_SECRET_ACCESS_KEY=your_r2_secret_key_here
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET_NAME=stock-data
